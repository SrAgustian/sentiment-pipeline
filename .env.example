# ============================================================
# .env — Konfigurasi kredensial proyek
# JANGAN commit file ini ke Git!
# Pastikan .env ada di dalam .gitignore
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=sentiment_user
POSTGRES_PASSWORD=ganti_password_ini_123
POSTGRES_DB=sentiment_db

# ── Airflow ───────────────────────────────────────────────────
# Generate fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=ganti_dengan_fernet_key_yang_digenerate

# Generate secret key: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_SECRET_KEY=ganti_dengan_secret_key_yang_digenerate

# Akun admin Airflow UI (localhost:8080)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=ganti_admin_password_ini
